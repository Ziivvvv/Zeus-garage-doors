                  <p className="text-xs text-charcoal/50 mt-0.5">{stat.sub}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── INTRO CONTENT */}
        <section
          className="py-16 lg:py-20 bg-offwhite"
